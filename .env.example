# Copy to .env and fill in your real values.
# .env is gitignored; .env.example is committed.
# scripts/run_preflight.py rsyncs .env to the server with the code,
# and the sbatch wrap sources it before running python.

# Hugging Face access token (https://huggingface.co/settings/tokens)
# Required for gated models (meta-llama/Llama-3.1-8B-Instruct) and to
# avoid the unauthenticated rate limit on dataset downloads.
HF_TOKEN=hf_your_huggingface_token_here
